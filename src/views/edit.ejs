<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Movie</title>
</head>
<body>
    <h1>Edit: <%= movie.title %> </h1>
    <p>Partial Update</p>
    <form action="/<%= movie.id %>?_method=PATCH" method="POST">
        <div>
            <label for="title">Title</label>
            <input
            type="text"
            id="title"
            name="title"
            value="<%= movie.title %>">

        </div>

        <div>
            <label for="director">Director</label>
            <input type="text" name="director" value="<%= movie.director %>">

        </div>

        <div>
            <label for="year">Year</label>
            <input type="text" name="year" value="<%= movie.year%>">
        </div>

        <button type="submit">Edit</button>
    </form>
    <p>Full Update:</p>
    <form action="/<%= movie.id%>?_method=PUT" method="POST">
        <div>
            <label for="title">Title</label>
            <input type="text" name="title" value="<%= movie.title%>">
        </div>
        <div> 
            <label for="director">Director</label>
            <input type="text" name="director" value="<%= movie.director%>"></div>
        <div>

        <div>
            <label for="year">Year</label>
            <input type="text" name="year" value="<%= movie.year%>"></div>

        </div>
        <button type="submit">Update</button>
    </form>

</body>
</html>

